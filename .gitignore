# LegalEase Project Gitignore

# User specific folders to ignore
/context/

# Maven (Backend) ignores
target/
*.releaseBackup
pom.xml.releaseBackup
pom.xml.tag
pom.xml.next
pom.xml.war
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# Node/Next.js (Frontend) ignores
node_modules/
.next/
out/
build/
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# System & IDE ignores
.DS_Store
.idea/
*.iml
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Antigravity agent & skills ignores
.agents/
*skills-lock.json

